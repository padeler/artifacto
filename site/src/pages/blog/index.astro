---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="All posts on Artifacto." />
		<style>
			.page-heading {
				margin-bottom: 2rem;
			}
			.page-heading h1 {
				font-size: 2rem;
				margin-bottom: 0.25rem;
			}
			.page-heading p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}
			.posts-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.post-item {
				display: block;
				padding: 1.25rem 1.5rem;
				background: var(--bg-card);
				border: 1px solid var(--border-subtle);
				border-radius: var(--radius-md);
				text-decoration: none;
				transition: all var(--transition-normal);
			}
			.post-item:hover {
				background: var(--bg-card-hover);
				border-color: var(--border-accent);
				box-shadow: var(--shadow-glow);
				transform: translateX(4px);
			}
			.post-item h3 {
				font-size: 1.15rem;
				font-weight: 600;
				color: var(--text-primary);
				margin: 0 0 0.35rem;
			}
			.post-item .post-summary {
				font-size: 0.9rem;
				color: var(--text-secondary);
				margin: 0 0 0.5rem;
				line-height: 1.5;
			}
			.post-item .post-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				flex-wrap: wrap;
			}
			.post-item .post-date {
				font-size: 0.8rem;
				color: var(--text-muted);
			}
			.post-item .post-tags {
				display: flex;
				gap: 0.4em;
				flex-wrap: wrap;
			}
			.post-item .post-tags .tag {
				font-size: 0.7rem;
				padding: 0.15em 0.5em;
			}
			.empty-state {
				text-align: center;
				padding: 4rem 1rem;
				color: var(--text-muted);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-heading">
				<h1>Blog</h1>
				<p>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
			</div>

			{posts.length > 0 ? (
				<ul class="posts-list">
					{posts.map((post) => (
						<li>
							<a class="post-item" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
								<h3>{post.data.title}</h3>
								<p class="post-summary">{post.data.summary}</p>
								<div class="post-meta">
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									{post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map((tag: string) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</div>
							</a>
						</li>
					))}
				</ul>
			) : (
				<div class="empty-state">
					<p>No posts yet. Start by ingesting your first artifact!</p>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
