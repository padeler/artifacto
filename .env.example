# Artifacto Configuration
# Copy this file to .env and fill in the values.

# -- LLM Provider --
# Options: claude_code | anthropic_api | ollama
LLM_PROVIDER=claude_code

# Anthropic API key (required if LLM_PROVIDER=anthropic_api)
ANTHROPIC_API_KEY=

# Ollama model name (required if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3

# -- GitHub --
# Repository in owner/repo format
GITHUB_REPO=padeler/artifacto

# -- Site --
SITE_BASE_URL=https://padeler.github.io/artifacto
